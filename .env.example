# Base panel API — local/dev config. Copy to .env and adjust.
APP_ENV=local

# Comma-separated allowed CORS origins (the panel frontends).
CORS_ALLOWED_ORIGINS=http://localhost:4321,https://management.tracht-digital.de,https://app.tracht-digital.de

# Auth — tds-auth-api base URL; the core fetches its JWKS to verify RS256 JWTs
# and build the request UserContext. Unset → every request is anonymous (routes
# then 401), so boot/local dev works without auth-api.
AUTH_API_URL=https://api.tracht-digital.de/auth
JWKS_CACHE_TTL=600

# DB — the shared PDO connection modules store their tables through (lazy, so
# boot stays DB-free until a route touches it).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tds_core_panel
DB_USER=root
DB_PASS=

# Core SMTP — the Mailer exposed to modules. Unset MAIL_DSN → a no-op mailer
# (modules can still call it; isConfigured() is false). DSN form:
# smtp://user:pass@host:port  (or the runtime settings store later).
MAIL_DSN=
MAIL_FROM=no-reply@tracht-digital.de
MAIL_FROM_NAME=Tracht Digital Solutions
